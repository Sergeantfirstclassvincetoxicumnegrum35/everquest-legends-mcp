{
  "name": "everquest-legends-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server for EverQuest Legends public sources.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "everquest-legends-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "everquest",
    "everquest-legends"
  ],
  "author": "Arthur Ariel Sabintsev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArtSabintsev/everquest-legends-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ArtSabintsev/everquest-legends-mcp/issues"
  },
  "homepage": "https://github.com/ArtSabintsev/everquest-legends-mcp#readme",
  "engines": {
    "node": ">=20.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
